{
  "name": "nebula-cluster",
  "version": "1.0.0",
  "description": "Nebula Cluster Distributed Orchestration Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:all": "concurrently --kill-others \"npm run dev -w apps/api\" \"npm run dev -w apps/dashboard\" \"npm run dev -w apps/worker\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:dashboard": "npm run dev -w apps/dashboard",
    "dev:worker": "npm run dev -w apps/worker",
    "provisioner-daemon": "npm run start -w apps/provisioner",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
